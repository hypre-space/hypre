#
# mixed-precision tests
# Tests mixed-precision AMG-PCG, AMG-GMRES and AMG-BiCGSTAB
#
# sequential
# mixed-precision AMG-PCG
mpirun -np 1  ./ij_mp -solver 1 -solver_precision 1 -pc_precision 0 > mixed-precision.out.600
# mixed-precision AMG-GMRES
mpirun -np 1  ./ij_mp -solver 11 -solver_precision 1 -pc_precision 0  > mixed-precision.out.601
# mixed-precision AMG-BiCGStab
mpirun -np 1  ./ij_mp -solver 31 -solver_precision 1 -pc_precision 0  > mixed-precision.out.602
# parallel
# AMG-PCG in single, double and mixed precision
mpirun -np 2  ./ij_mp -solver 1 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > mixed-precision.out.603
mpirun -np 2  ./ij_mp -solver 1 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > mixed-precision.out.604
mpirun -np 2  ./ij_mp -solver 1 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > mixed-precision.out.605
# AMG-GMRES in single, double and mixed precision
mpirun -np 2  ./ij_mp -solver 11 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > mixed-precision.out.606
mpirun -np 2  ./ij_mp -solver 11 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > mixed-precision.out.607
mpirun -np 2  ./ij_mp -solver 11 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > mixed-precision.out.608
# AMG-BiCGStab in single, double and mixed precision
mpirun -np 2  ./ij_mp -solver 31 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > mixed-precision.out.609
mpirun -np 2  ./ij_mp -solver 31 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > mixed-precision.out.610
mpirun -np 2  ./ij_mp -solver 31 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > mixed-precision.out.611
