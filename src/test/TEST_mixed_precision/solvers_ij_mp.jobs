#
# mixed-precision tests
# Tests mixed-precision AMG-PCG, AMG-GMRES and AMG-BiCGSTAB
#
# sequential
# mixed-precision AMG-PCG
mpirun -np 1  ./ij_mp -solver 1 -solver_precision 1 -pc_precision 0 > solvers_ij_mp.out.0
# mixed-precision AMG-GMRES
mpirun -np 1  ./ij_mp -solver 11 -solver_precision 1 -pc_precision 0  > solvers_ij_mp.out.1
# mixed-precision AMG-BiCGStab
mpirun -np 1  ./ij_mp -solver 31 -solver_precision 1 -pc_precision 0  > solvers_ij_mp.out.2
# parallel
# AMG-PCG in single, double and mixed precision
mpirun -np 2  ./ij_mp -solver 1 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > solvers_ij_mp.out.3
mpirun -np 2  ./ij_mp -solver 1 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > solvers_ij_mp.out.4
mpirun -np 2  ./ij_mp -solver 1 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > solvers_ij_mp.out.5
# AMG-GMRES in single, double and mixed precision
mpirun -np 2  ./ij_mp -solver 11 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > solvers_ij_mp.out.6
mpirun -np 2  ./ij_mp -solver 11 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > solvers_ij_mp.out.7
mpirun -np 2  ./ij_mp -solver 11 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > solvers_ij_mp.out.8
# AMG-BiCGStab in single, double and mixed precision
mpirun -np 2  ./ij_mp -solver 31 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > solvers_ij_mp.out.9
mpirun -np 2  ./ij_mp -solver 31 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > solvers_ij_mp.out.10
mpirun -np 2  ./ij_mp -solver 31 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > solvers_ij_mp.out.11
