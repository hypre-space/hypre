#
# mixed-precision tests
# Tests mixed-precision SMG-PCG, PFMG-PCG, PFMG-GMRES and PFMG-BiCGSTAB
#
# sequential
# mixed-precision PFMG-PCG
mpirun -np 1  ./struct_mp -solver 1 -n 10 10 10 -P 1 1 1 -solver_precision 1 -pc_precision 0 > solvers_struct_mp.out.0
# mixed-precision PFMG-GMRES
mpirun -np 1  ./struct_mp -solver 11 -n 10 10 10 -P 1 1 1 -solver_precision 1 -pc_precision 0  > solvers_struct_mp.out.1
# mixed-precision PFMG-BiCGStab
mpirun -np 1  ./struct_mp -solver 21 -n 10 10 10 -P 1 1 1 -solver_precision 1 -pc_precision 0  > solvers_struct_mp.out.2
# parallel
# PFMG-PCG in single, double and mixed precision
mpirun -np 2  ./struct_mp -solver 1 -n 20 10 10 -P 2 1 1 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > solvers_struct_mp.out.3
mpirun -np 2  ./struct_mp -solver 1 -n 20 10 10 -P 2 1 1 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > solvers_struct_mp.out.4
mpirun -np 2  ./struct_mp -solver 1 -n 20 10 10 -P 2 1 1 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > solvers_struct_mp.out.5
# PFMG-GMRES in single, double and mixed precision
mpirun -np 2  ./struct_mp -solver 11 -n 20 10 10 -P 2 1 1 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > solvers_struct_mp.out.6
mpirun -np 2  ./struct_mp -solver 11 -n 20 10 10 -P 2 1 1 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > solvers_struct_mp.out.7
mpirun -np 2  ./struct_mp -solver 11 -n 20 10 10 -P 2 1 1 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > solvers_struct_mp.out.8
# PFMG-BiCGStab in single, double and mixed precision
mpirun -np 2  ./struct_mp -solver 21 -n 20 10 10 -P 2 1 1 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > solvers_struct_mp.out.9
mpirun -np 2  ./struct_mp -solver 21 -n 20 10 10 -P 2 1 1 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > solvers_struct_mp.out.10
mpirun -np 2  ./struct_mp -solver 21 -n 20 10 10 -P 2 1 1 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > solvers_struct_mp.out.11
# SMG-PCG in single, double and mixed precision
mpirun -np 2  ./struct_mp -solver 0 -n 20 10 10 -P 2 1 1 -solver_precision 0 -pc_precision 0 -tol 1.0e-5 > solvers_struct_mp.out.12
mpirun -np 2  ./struct_mp -solver 0 -n 20 10 10 -P 2 1 1 -solver_precision 1 -pc_precision 1 -tol 1.0e-8 > solvers_struct_mp.out.13
mpirun -np 2  ./struct_mp -solver 0 -n 20 10 10 -P 2 1 1 -solver_precision 1 -pc_precision 0 -tol 1.0e-8 > solvers_struct_mp.out.14